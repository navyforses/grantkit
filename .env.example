# GrantKit Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_APP_ID=
NODE_ENV=development

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/grantkit

# Authentication
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=

# Forge API
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Paddle (Payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Resend (Email)
RESEND_API_KEY=

# MCP Toolbox for Databases (https://github.com/googleapis/mcp-toolbox)
# Start the server with: pnpm toolbox:start
# The toolbox reads tools.yaml and connects to MySQL using the vars below.
MCP_TOOLBOX_URL=http://localhost:5000

# MySQL connection vars used by tools.yaml
# These can be parsed from DATABASE_URL: mysql://USER:PASSWORD@HOST:PORT/DB
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=grantkit
MYSQL_USER=root
MYSQL_PASSWORD=
