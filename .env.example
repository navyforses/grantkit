# GrantKit Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_APP_ID=
NODE_ENV=development

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/grantkit

# Authentication
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=

# Forge API
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Paddle (Payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Resend (Email)
RESEND_API_KEY=

# Mapbox (Interactive World Map on /catalog + server-side geocoding)
# Get your token at https://account.mapbox.com/
VITE_MAPBOX_TOKEN=
MAPBOX_ACCESS_TOKEN=pk.xxx   # server-side geocoding (scripts/geocode-grants.ts)

# Supabase (SOCIAL / MEDICAL / GRANT resource tabs)
# Create a project at https://supabase.com and run supabase/migration.sql in the SQL Editor
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
