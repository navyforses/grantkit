# GrantKit Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_APP_ID=
NODE_ENV=development

# Backend URL (set this on Vercel to point at your Railway backend)
# Example: https://grantkit-production-06f7up.railway.app
VITE_API_URL=

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/grantkit

# Authentication
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=

# Forge API
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Paddle (Payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Resend (Email)
RESEND_API_KEY=
