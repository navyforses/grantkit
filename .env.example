# GrantKit Environment Variables
# Copy this file to .env and fill in the values

# Application
VITE_APP_ID=
NODE_ENV=development

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/grantkit

# Authentication
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=

# Forge API
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Paddle (Payments)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Resend (Email)
RESEND_API_KEY=

# Google Maps JavaScript API (LocationMap on /grant/:id + MapPanel on /catalog)
# Two separate keys — never ship GOOGLE_MAPS_API_KEY to the browser.
#
# Browser key (frontend, Vite-injected):
#   1. Google Cloud Console → Credentials → Create API key
#   2. Application restrictions: HTTP referrers → add:
#        https://grantkit-production-06f7up.railway.app/*
#        http://localhost:5173/*
#        http://localhost:3000/*
#   3. API restrictions: "Maps JavaScript API" + "Places API (New)"
#   4. Required: a Map ID → Google Cloud Console → Map Management
#      (advanced markers need vector maps, which require a mapId)
VITE_GOOGLE_MAPS_BROWSER_KEY=AIza...   # client-side maps (Catalog + GrantDetail)
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID    # or your own vector Map ID from Cloud Console
#
# Server key (backend only — used by scripts/geocode-grants.ts):
#   IP-restricted or unrestricted. API restrictions: "Places API (New)".
GOOGLE_MAPS_API_KEY=AIza...

# Supabase (SOCIAL / MEDICAL / GRANT resource tabs)
# Create a project at https://supabase.com and run supabase/migration.sql in the SQL Editor
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
